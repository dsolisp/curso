          ]
        }
      },
      "response": []
    },
    {
      "name": "06 · GET Post inexistente (caso negativo)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Caso negativo: pedir un recurso que NO existe debe dar 404",
              "pm.test('Status es 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('El cuerpo de la respuesta es un objeto vacío', function () {",
              "    pm.expect(pm.response.json()).to.eql({});",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
