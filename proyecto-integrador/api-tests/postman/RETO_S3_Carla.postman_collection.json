{
  "info": {
    "_postman_id": "7086fefc-b067-45cc-9e41-f20661af6455",
    "name": "RETO_S3_Carla",
    "description": "Sesión 3 — Flujo CRUD completo sobre JSONPlaceholder.\nDemuestra: variables de entorno, pre-request scripts, tests en JavaScript y validación con JSON Schema.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "14883671"
  },
  "item": [
    {
      "name": "01 · GET Listar usuarios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Responde en menos de 2 segundos', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test('El header Content-Type es JSON', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test('Devuelve la lista completa de 10 posts', function () {",
              "    const posts = pm.response.json();",
              "    pm.expect(posts).to.be.an('array');",
              "    pm.expect(posts).to.have.lengthOf(10);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "apikey",
          "apikey": [
            {
              "key": "key",
              "value": "api-key",
              "type": "string"
            },
            {
              "key": "value",
              "value": "{{auth_secret_12mq}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{payload}}"
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 · GET Detalle de un usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Contrato de la API: si la estructura cambia, este test falla",
              "const postSchema = {",
              "    type: 'object',",
              "    required: ['userId', 'id', 'title', 'body'],",
              "    properties: {",
              "        userId: { type: 'integer' },",
              "        id: { type: 'integer' },",
              "        title: { type: 'string' },",
              "        body: { type: 'string' }",
              "    }",
              "};",
              "",
              "pm.test('El post cumple el contrato (JSON Schema)', function () {",
              "    pm.response.to.have.jsonSchema(postSchema);",
              "});",
              "",
              "pm.test('El post pedido es el id=1', function () {",
              "    pm.expect(pm.response.json().id).to.eql(1);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 · POST Crear usuario",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Se ejecuta ANTES de enviar el request: genera un título único",
              "const titulo = 'Post QA ' + Date.now();",
              "pm.collectionVariables.set('dynamic_title', titulo);",
              "console.log('Título generado:', titulo);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('El post creado tiene un id asignado', function () {",
              "    const post = pm.response.json();",
              "    pm.expect(post.id).to.be.a('number');",
              "    // Encadenamiento: el id queda disponible para requests siguientes",
              "    pm.collectionVariables.set('post_id', post.id);",
              "});",
              "",
              "pm.test('El título devuelto es el que enviamos', function () {",
              "    const enviado = pm.collectionVariables.get('dynamic_title');",
              "    pm.expect(pm.response.json().title).to.eql(enviado);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{dynamic_title}}\",\n  \"body\": \"Creado desde la Sesión 3 del curso\",\n  \"userId\": 3\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "04 · PUT Actualizar usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El título quedó actualizado', function () {",
              "    pm.expect(pm.response.json().title).to.eql('Título actualizado en Sesión 3');",
              "});",
              "",
              "pm.test('El body quedó actualizado', function () {",
              "    pm.expect(pm.response.json().body).to.include('actualizado');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"title\": \"Título actualizado en Sesión 3 para users\",\n  \"body\": \"Contenido actualizado desde Postman\",\n  \"userId\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "05 · DELETE Eliminar usuario",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('El cuerpo de la respuesta es un objeto vacío', function () {",
              "    pm.expect(pm.response.json()).to.eql({});",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "packages": {},
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/89",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
